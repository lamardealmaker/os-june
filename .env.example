# Copy to .env for local development. Do not commit real secrets.

# Required for real transcription and note generation.
# When omitted, the app uses the local mock provider.
OPENAI_API_KEY=

# Optional: force a provider. Valid values: openai, mock.
# Leave empty to use openai when OPENAI_API_KEY is set, otherwise mock.
OS_NOTETAKER_PROVIDER=

# Optional model overrides.
OS_NOTETAKER_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OS_NOTETAKER_GENERATION_MODEL=gpt-5.2

# Optional: force transcription language with an ISO-639-1 code.
# Example for Spanish: es. Leave empty for auto-detection.
OS_NOTETAKER_TRANSCRIPTION_LANGUAGE=
